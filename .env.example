# Resend — https://resend.com (verify a sending domain for production inboxes)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional — defaults to vidit@curiositycentre.com
REPORT_PDF_NOTIFY_EMAIL=

# Airtable — "Playbooks Form Submissions"–style setup uses two tables (latest vs past).
# Each table needs columns: Full name, Company, Email
AIRTABLE_PERSONAL_ACCESS_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_LATEST=Latest edition submissions
AIRTABLE_TABLE_PAST=Past editions submissions
AIRTABLE_TABLE_PARTNER=Partner with us submissions
